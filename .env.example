DATABASE_URL=postgresql://rag:rag@db:5432/rag
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PDF_DIR=pdfs
CHUNK_MAX_TOKENS=400
RETRIEVAL_TOP_K=5

# Embedding model (sentence-transformers, downloaded automatically on first run)
# all-MiniLM-L6-v2  → 384 dims — fast, good for testing (default)
# allenai-specter2  → 768 dims — better for academic papers, set EMBEDDING_DIM=768
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
